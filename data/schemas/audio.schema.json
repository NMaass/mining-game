{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "res://data/schemas/audio.schema.json",
  "title": "Audio placeholder SFX and music data",
  "type": "object",
  "required": ["events", "combo", "detonate", "music"],
  "properties": {
    "events": {
      "type": "object",
      "additionalProperties": { "$ref": "#/$defs/sfx_event" }
    },
    "combo": {
      "type": "object",
      "required": ["max_voices", "step_seconds", "semitone_step"],
      "properties": {
        "max_voices": { "type": "integer", "minimum": 1 },
        "step_seconds": { "type": "number", "exclusiveMinimum": 0 },
        "semitone_step": { "type": "number", "minimum": 0 }
      }
    },
    "detonate": {
      "type": "object",
      "required": ["layers"],
      "properties": {
        "layers": {
          "type": "array",
          "minItems": 3,
          "items": { "$ref": "#/$defs/sfx_event" }
        }
      }
    },
    "music": {
      "type": "object",
      "required": ["music_menu", "music_mining", "music_deep", "music_relic", "music_shop"],
      "additionalProperties": false,
      "properties": {
        "music_menu": { "$ref": "#/$defs/music_loop" },
        "music_mining": { "$ref": "#/$defs/music_loop" },
        "music_deep": { "$ref": "#/$defs/music_loop" },
        "music_relic": { "$ref": "#/$defs/music_loop" },
        "music_shop": { "$ref": "#/$defs/music_loop" }
      }
    }
  },
  "$defs": {
    "sfx_event": {
      "type": "object",
      "required": ["freq", "dur", "noise", "sweep", "pitch_jitter"],
      "properties": {
        "freq": { "type": "number", "exclusiveMinimum": 0 },
        "dur": { "type": "number", "exclusiveMinimum": 0, "maximum": 2 },
        "noise": { "type": "number", "minimum": 0, "maximum": 1 },
        "sweep": { "type": "number", "minimum": 0 },
        "pitch_jitter": { "type": "number", "minimum": 0, "maximum": 0.5 }
      }
    },
    "music_loop": {
      "type": "object",
      "required": ["bpm", "step_beats", "volume", "notes"],
      "properties": {
        "bpm": { "type": "number", "exclusiveMinimum": 0 },
        "step_beats": { "type": "number", "exclusiveMinimum": 0 },
        "volume": { "type": "number", "minimum": 0, "maximum": 1 },
        "notes": {
          "type": "array",
          "minItems": 1,
          "items": { "type": "number", "minimum": 0 }
        }
      }
    }
  }
}
