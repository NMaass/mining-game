; Engine configuration file.
; Mining Game — vertical slice (steps 1–3). Godot 4.6.x.
; Tunables live in /data as schema-validated JSON; never hardcode balance.

config_version=5

[application]

config/name="Mining Game (Vertical Slice)"
config/description="Vertical slice: drag-aim + throw, destructible block level, finite run, money."
run/main_scene="res://scenes/main.tscn"
config/features=PackedStringArray("4.6", "GL Compatibility")
boot_splash/show_image=false

[autoload]

GameData="*res://scripts/systems/game_data.gd"
GameLog="*res://scripts/systems/logger.gd"
Audio="*res://scripts/systems/audio.gd"

[audio]

buses/default_bus_layout="res://default_bus_layout.tres"

[display]

window/size/viewport_width=720
window/size/viewport_height=1280
window/size/window_width_override=810
window/size/window_height_override=1440
window/size/resizable=true
window/stretch/mode="canvas_items"
window/stretch/aspect="keep"
window/handheld/orientation="portrait"

[editor_plugins]

enabled=PackedStringArray("res://addons/gdUnit4/plugin.cfg")

[input]

; Keyboard controls (D1). These ADD to the existing mouse/single-touch path (which stays the
; canonical input — aim/throw parity is structural per AC-5.3.7); they never replace it. Held
; aim_left/aim_right nudge the launch angle smoothly (forgiving, AC-5.3.1/5.3.2); fire commits a
; throw through the SAME path as the throw button (AC-5.3.3); elevator_up/down mirror the on-screen
; elevator arrows (AC-5.7.2). The rebinding UI is a later unit; these are sensible defaults only.
; cycle_charge (Tab) + select_prev/select_next (Q/E) step the charge-selector hotbar (AC-5.3.6);
; select_prev/next are NOT in SettingsState.KEYBIND_ACTIONS (fixed bindings, like cycle_charge).
; ←/→ are held-aim only (aim_left/aim_right, polled) — they no longer also cycle the selector, so no
; key does two things by press duration (AC-5.3.7: no timing-precision inputs).
aim_left={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":4194319,"key_label":0,"unicode":0,"location":0,"echo":false,"script":null)
]
}
